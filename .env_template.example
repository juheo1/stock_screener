# -------------------------------------------------------
# Stock Screener - Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# FRED API key (free — sign up at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Database path (SQLite local file)
DATABASE_URL=sqlite:///./data/stock_screener.db

# FastAPI settings
API_HOST=127.0.0.1
API_PORT=8000

# Dash frontend settings
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=false

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Scheduler settings
# Cron expression for daily data refresh (default: 6:30 AM)
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=30

# Log level
LOG_LEVEL=INFO
